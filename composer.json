{
    "name": "ptgs/php-type-bridge",
    "description": "Static API contract collection and TypeScript generation for PHP APIs",
    "type": "library",
    "license": "MIT",
    "keywords": ["php", "typescript", "api", "static-analysis", "symfony"],
    "homepage": "https://github.com/RentBetter/php-type-bridge",
    "repositories": [
        {
            "type": "vcs",
            "url": "https://github.com/RentBetter/phpstan-rules"
        }
    ],
    "require": {
        "php": ">=8.4",
        "symfony/config": "^7.3 || ^8.0",
        "symfony/console": "^7.3 || ^8.0",
        "symfony/dependency-injection": "^7.3 || ^8.0",
        "symfony/event-dispatcher": "^7.3 || ^8.0",
        "symfony/form": "^7.3 || ^8.0",
        "symfony/http-foundation": "^7.3 || ^8.0",
        "symfony/http-kernel": "^7.3 || ^8.0",
        "symfony/routing": "^7.3 || ^8.0",
        "symfony/validator": "^7.3 || ^8.0"
    },
    "require-dev": {
        "phpstan/extension-installer": "^1.4",
        "phpstan/phpstan": "^2.1",
        "phpstan/phpstan-symfony": "^2.0",
        "phpunit/phpunit": "^11.0",
        "ptgs/phpstan-rules": "dev-main"
    },
    "autoload": {
        "psr-4": {
            "PTGS\\TypeBridge\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PTGS\\TypeBridge\\Tests\\": "tests/"
        },
        "classmap": [
            "tests/Stubs/"
        ]
    },
    "scripts": {
        "phpstan": "phpstan analyse --memory-limit=1G",
        "test": "phpunit"
    },
    "config": {
        "allow-plugins": {
            "phpstan/extension-installer": true
        },
        "sort-packages": true
    },
    "extra": {
        "phpstan": {
            "includes": [
                "extension.neon"
            ]
        },
        "phpstan/extension-installer": {
            "ignore": [
                "ptgs/phpstan-rules"
            ]
        }
    }
}
