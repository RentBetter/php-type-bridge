{
    "name": "rentbetter/php-type-bridge",
    "description": "Static API contract collection and TypeScript generation for PHP APIs",
    "type": "library",
    "license": "MIT",
    "keywords": ["php", "typescript", "api", "static-analysis", "symfony"],
    "homepage": "https://github.com/RentBetter/php-type-bridge",
    "require": {
        "php": ">=8.4",
        "symfony/console": "^7.3 || ^8.0",
        "symfony/form": "^7.3 || ^8.0",
        "symfony/http-kernel": "^7.3 || ^8.0"
    },
    "require-dev": {
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "PTGS\\TypeBridge\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PTGS\\TypeBridge\\Tests\\": "tests/"
        },
        "classmap": [
            "tests/Stubs/"
        ]
    },
    "config": {
        "sort-packages": true
    },
    "extra": {
        "phpstan": {
            "includes": [
                "extension.neon"
            ]
        }
    }
}
