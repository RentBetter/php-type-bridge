# Auto-loaded by consumers via composer extra.phpstan.includes.
#
# Holds only rules that are safe for any consumer of TypeBridge regardless of
# whether they have adopted the V2 contract conventions. The EnumIdSource rule
# fires solely on classes carrying #[EnumIdSource], so it never touches code that
# does not opt in. The V2 contract-enforcement rules live in rules.neon (opt-in).
services:
    -
        class: PTGS\TypeBridge\PHPStan\Rules\Enum\EnumIdSourceReturnTypeRule
        tags:
            - phpstan.rules.rule
